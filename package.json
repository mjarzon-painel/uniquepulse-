{
  "name": "whatsapp-blast-manager",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node server/index.js",
    "tunnel": "cloudflared tunnel --url http://localhost:3001 --no-autoupdate",
    "start": "concurrently -n web,wa -c green,blue \"npm run dev\" \"npm run server\"",
    "start:remote": "concurrently -n web,wa,tunnel -c green,blue,magenta \"npm run dev\" \"npm run server\" \"npm run tunnel\"",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "lucide-react": "^0.379.0",
    "papaparse": "^5.4.1",
    "qrcode": "^1.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "whatsapp-web.js": "^1.26.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/papaparse": "^5.3.14",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.2.13"
  }
}
