# ============================================================
#  BACKEND (.env) — copie para ".env" na raiz do projeto
# ============================================================

# Chave de acesso do backend. Defina ao expor o backend na internet.
# Sem WA_TOKEN, o backend fica ABERTO (ok só para uso local no mesmo PC).
WA_TOKEN=troque-por-uma-chave-forte-aqui

# Webhook da Cloud API (respostas recebidas).
# WEBHOOK_VERIFY_TOKEN: valor que você digita no painel da Meta ao cadastrar o webhook.
WEBHOOK_VERIFY_TOKEN=troque-por-um-verify-token

# META_APP_SECRET (opcional, recomendado): valida a assinatura das requisições do webhook.
# Pegue em developers.facebook.com → seu app → Configurações → Básico → Chave secreta do app.
# Se vazio, o webhook aceita sem validar assinatura.
META_APP_SECRET=

# ============================================================
#  FRONTEND (Render → Environment, ou .env.local no dev)
#  Variáveis VITE_* parametrizam a instância por empresa.
# ============================================================
# VITE_API_URL=https://seu-backend.ngrok-free.dev   # URL pública do backend
# VITE_LOGIN_USER=admin
# VITE_LOGIN_PASS=troque-a-senha
# VITE_BRAND_NAME=UniquePulse          # nome exibido no painel
# VITE_BRAND_HIGHLIGHT=Pulse           # parte do nome destacada em cor (sufixo)
# VITE_BRAND_TAGLINE=Disparos WhatsApp — Sua Empresa
# VITE_BRAND_LOGO_ICON=/logo-icon.png  # troque os arquivos em public/ por empresa
# VITE_BRAND_LOGO_FULL=/logo-full.png
